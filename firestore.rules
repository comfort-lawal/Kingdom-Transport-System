// Firestore Security Rules for Kingdom Transport System
// Deploy these in Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user is admin (A.S.O)
    function isAdmin() {
      return isAuth() && request.auth.token.email == 'oluwaselawal@gmail.com';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && (request.auth.uid == userId || isAdmin());
    }

    // Rotation collection (keke ownership)
    match /rotation/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin(); // Only admin can modify rotation/bank details
    }

    // Transfers collection
    match /transfers/{transferId} {
      allow read: if isAuth();
      allow create: if isAuth(); // Any collaborator can log a transfer
      allow update: if isAdmin(); // Only admin can approve/reject
    }

    // Notifications collection
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid; // Mark own as read
    }
  }
}
